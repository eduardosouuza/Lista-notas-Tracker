{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "excludeFiles": "{backend/test_*.py,backend/debug_page.py,backend/setup_db.py,backend/package*.json,backend/node_modules/**,.git/**,.vscode/**,db/**,supabase/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
